{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KOTOR Mod Installer",
  "version": "0.4.0",
  "identifier": "com.kotormods.installer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "KOTOR Mod Installer",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8756 ws://127.0.0.1:8756; img-src 'self' data: https: http://127.0.0.1:8756; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
